{
  "tools": [
    {
      "name": "git_status",
      "description": "Show working tree status: current branch, staged changes, unstaged changes, and untracked files.",
      "parameters": {
        "type": "object",
        "required": [],
        "properties": {
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_log",
      "description": "Show recent commit history.",
      "parameters": {
        "type": "object",
        "required": [],
        "properties": {
          "count": {
            "type": "string",
            "description": "Number of commits to show (e.g. '10'). Defaults to 10 if omitted."
          },
          "oneline": {
            "type": "boolean",
            "description": "Use compact one-line format per commit"
          },
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          },
          "file_path": {
            "type": "string",
            "description": "Limit log to commits affecting this file or directory path within the repository"
          }
        }
      }
    },
    {
      "name": "git_diff",
      "description": "Show differences between working tree, index, or commits.",
      "parameters": {
        "type": "object",
        "required": [],
        "properties": {
          "staged": {
            "type": "boolean",
            "description": "Show staged changes (index vs HEAD) instead of unstaged changes"
          },
          "ref": {
            "type": "string",
            "description": "Compare against a specific commit, branch, or ref (e.g. 'main', 'HEAD~3')"
          },
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          },
          "file_path": {
            "type": "string",
            "description": "Limit diff to a specific file or directory path within the repository"
          }
        }
      }
    },
    {
      "name": "git_show",
      "description": "Show the contents of a specific commit (message, author, diff).",
      "parameters": {
        "type": "object",
        "required": ["ref"],
        "properties": {
          "ref": {
            "type": "string",
            "description": "Commit hash, branch name, tag, or ref to show (e.g. 'HEAD', 'abc1234', 'main')"
          },
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_branch",
      "description": "List branches. Shows all local branches with the current branch marked.",
      "parameters": {
        "type": "object",
        "required": [],
        "properties": {
          "all": {
            "type": "boolean",
            "description": "Include remote-tracking branches"
          },
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_add",
      "description": "Stage files for the next commit.",
      "parameters": {
        "type": "object",
        "required": ["files"],
        "properties": {
          "files": {
            "type": "string",
            "description": "File path or pattern to stage (e.g. 'src/main.rs', '.')"
          },
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_commit",
      "description": "Create a new commit with staged changes.",
      "parameters": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string",
            "description": "Commit message describing the changes"
          },
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_branch_create",
      "description": "Create a new branch and switch to it.",
      "parameters": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name for the new branch (e.g. 'feature/add-search')"
          },
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_checkout",
      "description": "Switch to an existing branch.",
      "parameters": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Branch name to switch to (e.g. 'main', 'dev')"
          },
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_branch_delete",
      "description": "Delete a local branch.",
      "parameters": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Branch name to delete (e.g. 'feature/old-branch')"
          },
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_merge",
      "description": "Merge a branch into the current branch. Defaults to squash merge (--squash) which stages the combined diff without creating a merge commit — follow with git_commit to finalize.",
      "parameters": {
        "type": "object",
        "required": ["branch"],
        "properties": {
          "branch": {
            "type": "string",
            "description": "The branch to merge"
          },
          "squash": {
            "type": "boolean",
            "description": "Squash the branch's commits into a single staged change (default: true)"
          },
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_rebase",
      "description": "Rebase the current branch onto another branch or ref. Replays the current branch's commits on top of the target.",
      "parameters": {
        "type": "object",
        "required": ["onto"],
        "properties": {
          "onto": {
            "type": "string",
            "description": "The branch or ref to rebase onto (e.g. 'main', 'feat/my-feature')"
          },
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_cherry_pick",
      "description": "Apply the changes introduced by specific commits onto the current branch. Defaults to creating a new commit for each picked commit.",
      "parameters": {
        "type": "object",
        "required": ["commits"],
        "properties": {
          "commits": {
            "type": "string",
            "description": "One or more commit hashes to cherry-pick (space-separated for multiple, e.g. 'abc1234' or 'abc1234 def5678')"
          },
          "no_commit": {
            "type": "boolean",
            "description": "Stage changes without committing — follow with git_commit to finalize (default: false)"
          },
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_rebase_continue",
      "description": "Continue a rebase after resolving conflicts. Stage resolved files with git_add first, then run this to proceed.",
      "parameters": {
        "type": "object",
        "required": [],
        "properties": {
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_rebase_abort",
      "description": "Abort an in-progress rebase and restore the original branch state.",
      "parameters": {
        "type": "object",
        "required": [],
        "properties": {
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_cherry_pick_continue",
      "description": "Continue a cherry-pick after resolving conflicts. Stage resolved files with git_add first, then run this to proceed.",
      "parameters": {
        "type": "object",
        "required": [],
        "properties": {
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_cherry_pick_abort",
      "description": "Abort an in-progress cherry-pick and restore the original branch state.",
      "parameters": {
        "type": "object",
        "required": [],
        "properties": {
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    },
    {
      "name": "git_reset",
      "description": "Undo the last commit(s) on the current branch. Defaults to a mixed reset (HEAD~1) which undoes the commit but keeps changes staged — follow with git_commit to re-commit or git_status to inspect.",
      "parameters": {
        "type": "object",
        "required": [],
        "properties": {
          "ref": {
            "type": "string",
            "description": "The ref to reset to (default: 'HEAD~1')"
          },
          "path": {
            "type": "string",
            "description": "Repository path relative to the sandbox root (use ./ prefix). Defaults to the sandbox root if omitted."
          }
        }
      }
    }
  ],
  "allowlist": {
    "git": ["status", "log", "diff", "show", "branch", "add", "commit -F -", "checkout -b", "checkout", "branch -d", "merge", "rebase", "cherry-pick", "reset"]
  },
  "execution": [
    {
      "tool": "git_status",
      "binary": "git",
      "subcommand": "status",
      "args": [
        { "param": "path", "kind": "workingdir", "optional": true, "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] } }
      ],
      "successExitCodes": [128],
      "postProcess": {
        "script": "hint-not-repo"
      }
    },
    {
      "tool": "git_log",
      "binary": "git",
      "subcommand": "log",
      "args": [
        { "param": "count", "kind": "flag", "flag": "n", "optional": true, "absentDefault": "10" },
        { "param": "oneline", "kind": "flagifboolean", "flagIfTrue": "--oneline" },
        { "param": "file_path", "kind": "positional", "optional": true },
        { "param": "path", "kind": "workingdir", "optional": true, "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] } }
      ],
      "maxOutputLines": 200
    },
    {
      "tool": "git_diff",
      "binary": "git",
      "subcommand": "diff",
      "args": [
        { "param": "staged", "kind": "flagifboolean", "flagIfTrue": "--cached" },
        { "param": "ref", "kind": "positional", "optional": true },
        { "param": "file_path", "kind": "positional", "optional": true, "disambiguateAfterSkippedPositionals": true },
        { "param": "path", "kind": "workingdir", "optional": true, "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] } }
      ],
      "maxOutputLines": 200,
      "postProcess": {
        "script": "hint-diff-ref-main",
        "args": ["$ref"]
      }
    },
    {
      "tool": "git_show",
      "binary": "git",
      "subcommand": "show",
      "args": [
        { "param": "ref", "kind": "positional" },
        { "param": "path", "kind": "workingdir", "optional": true, "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] } }
      ],
      "maxOutputLines": 200
    },
    {
      "tool": "git_branch",
      "binary": "git",
      "subcommand": "branch",
      "args": [
        { "param": "all", "kind": "flagifboolean", "flagIfTrue": "--all" },
        { "param": "path", "kind": "workingdir", "optional": true, "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] } }
      ],
      "maxOutputLines": 200
    },
    {
      "tool": "git_add",
      "binary": "git",
      "subcommand": "add",
      "args": [
        { "param": "files", "kind": "positional", "split": true },
        { "param": "path", "kind": "workingdir", "optional": true, "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] } }
      ]
    },
    {
      "tool": "git_commit",
      "binary": "git",
      "subcommand": "commit -F -",
      "args": [
        { "param": "message", "kind": "stdin" },
        {
          "param": "path",
          "kind": "workingdir",
          "optional": true,
          "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] },
          "denyPattern": "^release/.+$",
          "denyAlwaysResolve": true,
          "denyResolveCommand": { "script": "resolve-current-branch", "args": ["$workingDir"] }
        }
      ],
      "successExitCodes": [1],
      "postProcess": {
        "script": "hint-commit-status"
      }
    },
    {
      "tool": "git_branch_create",
      "binary": "git",
      "subcommand": "checkout -b",
      "args": [
        { "param": "name", "kind": "positional" },
        { "param": "path", "kind": "workingdir", "optional": true, "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] } }
      ]
    },
    {
      "tool": "git_checkout",
      "binary": "git",
      "subcommand": "checkout",
      "args": [
        { "param": "name", "kind": "positional" },
        { "param": "path", "kind": "workingdir", "optional": true, "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] } }
      ]
    },
    {
      "tool": "git_branch_delete",
      "binary": "git",
      "subcommand": "branch -d",
      "args": [
        { "param": "name", "kind": "positional", "denyPattern": "^(main|release/.+)$" },
        { "param": "path", "kind": "workingdir", "optional": true, "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] } }
      ]
    },
    {
      "tool": "git_merge",
      "binary": "git",
      "subcommand": "merge",
      "args": [
        { "param": "squash", "kind": "flagifboolean", "flagIfTrue": "--squash", "optional": true },
        { "param": "branch", "kind": "positional" },
        {
          "param": "path",
          "kind": "workingdir",
          "optional": true,
          "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] },
          "denyPattern": "^release/.+$",
          "denyAlwaysResolve": true,
          "denyResolveCommand": { "script": "resolve-current-branch", "args": ["$workingDir"] }
        }
      ],
      "successExitCodes": [1],
      "maxOutputLines": 50,
      "postProcess": {
        "script": "hint-merge",
        "args": ["$squash"]
      }
    },
    {
      "tool": "git_rebase",
      "binary": "git",
      "subcommand": "rebase",
      "args": [
        { "param": "onto", "kind": "positional" },
        {
          "param": "path",
          "kind": "workingdir",
          "optional": true,
          "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] },
          "denyPattern": "^(main|release/.+)$",
          "denyAlwaysResolve": true,
          "denyResolveCommand": { "script": "resolve-current-branch", "args": ["$workingDir"] }
        }
      ],
      "successExitCodes": [1],
      "maxOutputLines": 50,
      "postProcess": {
        "script": "hint-rebase"
      }
    },
    {
      "tool": "git_cherry_pick",
      "binary": "git",
      "subcommand": "cherry-pick",
      "args": [
        { "param": "no_commit", "kind": "flagifboolean", "flagIfTrue": "--no-commit", "optional": true },
        { "param": "commits", "kind": "positional", "split": true },
        {
          "param": "path",
          "kind": "workingdir",
          "optional": true,
          "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] },
          "denyPattern": "^release/.+$",
          "denyAlwaysResolve": true,
          "denyResolveCommand": { "script": "resolve-current-branch", "args": ["$workingDir"] }
        }
      ],
      "successExitCodes": [1],
      "maxOutputLines": 50,
      "postProcess": {
        "script": "hint-cherry-pick",
        "args": ["$no_commit"]
      }
    },
    {
      "tool": "git_rebase_continue",
      "binary": "git",
      "subcommand": "rebase",
      "args": [
        { "kind": "literal", "value": "--continue" },
        {
          "param": "path",
          "kind": "workingdir",
          "optional": true,
          "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] },
          "denyPattern": "^(main|release/.+)$",
          "denyAlwaysResolve": true,
          "denyResolveCommand": { "script": "resolve-current-branch", "args": ["$workingDir"] }
        }
      ],
      "successExitCodes": [1],
      "maxOutputLines": 50
    },
    {
      "tool": "git_rebase_abort",
      "binary": "git",
      "subcommand": "rebase",
      "args": [
        { "kind": "literal", "value": "--abort" },
        { "param": "path", "kind": "workingdir", "optional": true, "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] } }
      ],
      "maxOutputLines": 50
    },
    {
      "tool": "git_cherry_pick_continue",
      "binary": "git",
      "subcommand": "cherry-pick",
      "args": [
        { "kind": "literal", "value": "--continue" },
        {
          "param": "path",
          "kind": "workingdir",
          "optional": true,
          "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] },
          "denyPattern": "^release/.+$",
          "denyAlwaysResolve": true,
          "denyResolveCommand": { "script": "resolve-current-branch", "args": ["$workingDir"] }
        }
      ],
      "successExitCodes": [1],
      "maxOutputLines": 50
    },
    {
      "tool": "git_cherry_pick_abort",
      "binary": "git",
      "subcommand": "cherry-pick",
      "args": [
        { "kind": "literal", "value": "--abort" },
        { "param": "path", "kind": "workingdir", "optional": true, "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] } }
      ],
      "maxOutputLines": 50
    },
    {
      "tool": "git_reset",
      "binary": "git",
      "subcommand": "reset",
      "args": [
        { "param": "ref", "kind": "positional", "optional": true, "absentDefault": "HEAD~1" },
        {
          "param": "path",
          "kind": "workingdir",
          "optional": true,
          "resolveCommand": { "script": "resolve-repo-path", "args": ["$param"] },
          "denyPattern": "^(main|release/.+)$",
          "denyAlwaysResolve": true,
          "denyResolveCommand": { "script": "resolve-current-branch", "args": ["$workingDir"] }
        }
      ],
      "maxOutputLines": 50,
      "postProcess": {
        "script": "hint-reset",
        "args": ["$ref"]
      }
    }
  ]
}
