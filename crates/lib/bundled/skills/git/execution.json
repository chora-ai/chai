[
  {
    "tool": "git_status",
    "binary": "git",
    "subcommand": "status",
    "args": [
      {
        "param": "repo",
        "kind": "workingdir",
        "optional": true,
        "resolveCommand": {
          "binary": "chai",
          "subcommand": "resolve repo-path",
          "args": ["--path", "$param"]
        }
      }
    ],
    "successExitCodes": [128],
    "hintConditions": [
      {
        "match": "not a git repository",
        "hint": "not a git repository — specify a valid repo path"
      }
    ]
  },
  {
    "tool": "git_log",
    "binary": "git",
    "subcommand": "log",
    "args": [
      {
        "param": "count",
        "kind": "flag",
        "flag": "n",
        "optional": true,
        "absentDefault": "10"
      },
      { "param": "skip", "kind": "flag", "flag": "skip", "optional": true },
      {
        "param": "oneline",
        "kind": "flagifboolean",
        "flagIfTrue": "--oneline"
      },
      {
        "param": "path",
        "kind": "positional",
        "optional": true,
        "disambiguateAfterSkippedPositionals": true
      },
      {
        "param": "repo",
        "kind": "workingdir",
        "optional": true,
        "resolveCommand": {
          "binary": "chai",
          "subcommand": "resolve repo-path",
          "args": ["--path", "$param"]
        }
      }
    ],
    "maxOutputLines": 200,
    "truncationHint": "output truncated: {kept} of {total} lines shown; {omitted} more lines available. To paginate, use skip with the same count; use oneline: true for compact output."
  },
  {
    "tool": "git_diff",
    "binary": "git",
    "subcommand": "diff",
    "args": [
      {
        "param": "staged",
