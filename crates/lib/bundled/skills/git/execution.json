  {
    "tool": "git_commit",
    "binary": "git",
    "subcommand": "commit -F -",
    "args": [
      { "param": "message", "kind": "stdin" },
      {
        "param": "repo",
        "kind": "workingdir",
        "optional": true,
        "resolveCommand": {
          "binary": "chai",
          "subcommand": "resolve repo-path",
          "args": ["--path", "$param"]
        },
        "denyPattern": "^release/.+$",
        "denyAlwaysResolve": true,
        "denyResolveCommand": {
          "script": "resolve-current-branch",
          "args": ["$workingDir"]
        }
      }
    ],
    "successExitCodes": [1],
    "hintConditions": [
      {
        "match": "nothing to commit",
        "hint": "nothing to commit — working tree clean"
      },
      {
        "match": "no changes added",
        "hint": "unstaged changes present — use git_add to stage them"
      },
      {
        "match": "untracked files",
        "hint": "untracked files present — use git_status to see them"
      }
    ]
  },
  {
