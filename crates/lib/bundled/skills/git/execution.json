    "maxOutputLines": 200,
    "truncationHint": "output truncated: {kept} of {total} lines shown; {omitted} more lines available. To continue reading, use git_diff_lines with start_line: {next_start}; omit end_line to read the rest.",
    "hintConditions": [
      {
        "whenArg": { "ref": "main" },
        "hint": "showing changes since diverging from main"
      }
    ]
  },
  {
    "tool": "git_diff_lines",
