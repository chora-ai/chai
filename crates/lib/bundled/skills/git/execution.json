      {
        "param": "path",
        "kind": "positional",
        "optional": true,
        "disambiguateAfterSkippedPositionals": true
      },
      {
        "param": "repo",
        "kind": "workingdir",
        "optional": true,
        "resolveCommand": {
          "binary": "chai",
          "subcommand": "resolve repo-path",
          "args": ["--path", "$param"]
        }
      }
