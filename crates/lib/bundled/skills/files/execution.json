      { "param": "pattern", "kind": "tempfile", "flag": "pattern-file" },
      { "param": "replacement", "kind": "stdin" },
      {
        "param": "literal",
        "kind": "flagifboolean",
        "flagIfTrue": "--literal"
      },
      {
        "param": "dry_run",
        "kind": "flagifboolean",
        "flagIfTrue": "--dry-run"
      }
    ],
    "maxOutputLines": 200
  },
