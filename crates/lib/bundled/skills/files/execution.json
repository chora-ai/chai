[
  {
    "tool": "files_read",
    "binary": "chai",
    "subcommand": "file read-lines",
    "args": [
      { "param": "path", "kind": "flag", "flag": "path", "readPath": true },
      {
        "param": "start_line",
        "kind": "flag",
        "flag": "start-line",
        "optional": true,
        "absentDefault": 1
      }
    ],
    "successExitCodes": [1],
    "hintConditions": [
      {
        "exitCode": "nonzero",
        "hint": "file not found — use files_list to list available files"
      }
    ],
    "maxOutputLines": 500,
    "truncationHint": "output truncated: {kept} of {total} lines shown; {omitted} more lines available. To continue reading, use files_read_lines with start_line: {next_start}; omit end_line to read the rest."
  },
  {
    "tool": "files_read_lines",
    "binary": "chai",
    "subcommand": "file read-lines",
    "args": [
      { "param": "path", "kind": "flag", "flag": "path", "readPath": true },
      { "param": "start_line", "kind": "flag", "flag": "start-line" },
      {
        "param": "end_line",
        "kind": "flag",
        "flag": "end-line",
        "optional": true
      }
    ],
    "successExitCodes": [1],
    "hintConditions": [
      {
        "exitCode": "nonzero",
        "hint": "file not found — use files_list to list available files"
      }
    ]
  },
  {
    "tool": "files_list",
    "binary": "ls",
    "subcommand": "",
    "args": [
      { "param": "long", "kind": "flagifboolean", "flagIfTrue": "-l" },
      { "param": "all", "kind": "flagifboolean", "flagIfTrue": "-a" },
      { "param": "path", "kind": "positional", "readPath": true }
    ],
    "maxOutputLines": 200,
    "postProcess": {
      "script": "sanitize-ls"
    },
    "sideRead": {
      "pathParam": "path",
      "filename": "AGENTS.md",
      "oncePerSession": true
    }
  },
  {
    "tool": "files_search",
    "binary": "grep",
    "subcommand": "-E --line-number",
    "args": [
      {
        "param": "recursive",
        "kind": "flagifboolean",
        "flagIfTrue": "--recursive",
        "absentDefault": true
      },
      {
        "param": "ignore_case",
        "kind": "flagifboolean",
        "flagIfTrue": "--ignore-case"
      },
      { "param": "pattern", "kind": "positional" },
      { "param": "path", "kind": "positional", "readPath": true }
    ],
    "successExitCodes": [0, 1],
    "hintConditions": [
      {
        "notEmpty": true,
        "hint": "use files_read_lines to read surrounding context"
      }
    ],
    "maxOutputLines": 200
  },
  {
    "tool": "files_write",
    "binary": "chai",
    "subcommand": "file write",
    "args": [
      { "param": "path", "kind": "flag", "flag": "path", "writePath": true },
      {
        "param": "content",
        "kind": "stdin"
      }
    ],
    "hintConditions": [
      {
        "match": "overwriting existing",
        "hint": "overwrote existing file — verify this was intended"
      }
    ]
  },
  {
    "tool": "files_write_lines",
    "binary": "chai",
