[
  {
    "tool": "files_read",
    "binary": "chai",
    "subcommand": "file read-lines",
    "args": [
      {
        "param": "path",
        "kind": "flag",
        "flag": "path",
        "readPath": true
      },
      {
        "param": "start_line",
        "kind": "flag",
        "flag": "start-line",
        "optional": true,
        "absentDefault": 1
      },
      {
        "param": "end_line",
        "kind": "flag",
        "flag": "end-line",
        "optional": true
      }
    ],
    "successExitCodes": [1],
    "hintConditions": [
      {
        "exitCode": "nonzero",
        "hint": "file not found — use files_list to list available files"
      }
    ],
    "maxOutputLines": 500,
    "truncationHint": "output truncated: {kept} of {total} lines shown; {omitted} more lines available. To continue reading, use files_read with start_line: {next_start}."
  },
  {
    "tool": "files_list",
    "binary": "ls",
    "subcommand": "",
    "args": [
      {
        "param": "long",
        "kind": "flagifboolean",
        "flagIfTrue": "-l"
      },
      {
        "param": "all",
        "kind": "flagifboolean",
        "flagIfTrue": "-a"
      },
      {
        "param": "path",
        "kind": "positional",
        "readPath": true
      }
    ],
    "maxOutputLines": 200,
    "postProcess": {
      "script": "sanitize-ls"
    },
    "sideRead": {
      "pathParam": "path",
      "filename": "AGENTS.md",
      "oncePerSession": true
    }
  },
  {
    "tool": "files_search",
    "binary": "grep",
    "subcommand": "-E --line-number",
    "args": [
      {
        "param": "recursive",
        "kind": "flagifboolean",
        "flagIfTrue": "--recursive",
        "absentDefault": true
      },
      {
        "param": "ignore_case",
        "kind": "flagifboolean",
        "flagIfTrue": "--ignore-case"
      },
      {
        "param": "pattern",
        "kind": "positional"
      },
      {
        "param": "path",
        "kind": "positional",
        "readPath": true
      }
    ],
    "successExitCodes": [0, 1],
    "hintConditions": [
      {
        "notEmpty": true,
        "hint": "use files_read to read surrounding context"
      }
    ],
    "maxOutputLines": 200
  },
  {
    "tool": "files_write",
    "binary": "chai",
    "subcommand": "file write",
    "paramCondition": {
      "absent": ["start_line", "original_content"]
    },
    "args": [
      {
        "param": "path",
        "kind": "flag",
        "flag": "path",
        "writePath": true
      },
      {
        "param": "content",
        "kind": "stdin"
      },
      {
        "param": "overwrite",
        "kind": "flagifboolean",
        "flagIfTrue": "--overwrite"
      }
    ],
    "successExitCodes": [1],
    "hintConditions": [
      {
        "match": "new file created",
        "whenArg": { "overwrite": true },
        "hint": "new file was created (no overwrite necessary, verify this was intended)"
      }
    ]
  },
  {
    "tool": "files_write",
    "binary": "chai",
    "subcommand": "file patch",
    "paramCondition": {
      "present": ["start_line", "original_content"]
    },
    "args": [
      {
        "param": "path",
        "kind": "flag",
        "flag": "path",
        "writePath": true
      },
      {
        "param": "start_line",
        "kind": "flag",
        "flag": "start-line"
      },
      {
        "param": "original_content",
        "kind": "tempfile",
        "flag": "original-content-file"
      },
      {
        "param": "content",
        "kind": "stdin"
      }
    ],
    "maxOutputLines": 200
  },
  {
    "tool": "files_replace",
    "binary": "chai",
    "subcommand": "file replace --line-number",
    "args": [
      {
        "param": "path",
        "kind": "flag",
        "flag": "path",
        "writePath": true
      },
      {
        "param": "pattern",
        "kind": "tempfile",
        "flag": "pattern-file"
      },
      {
        "param": "replacement",
        "kind": "stdin"
      },
      {
        "param": "literal",
        "kind": "flagifboolean",
        "flagIfTrue": "--literal"
      },
      {
        "param": "dry_run",
        "kind": "flagifboolean",
        "flagIfTrue": "--dry-run"
      }
    ],
    "maxOutputLines": 200
  },
  {
    "tool": "files_delete",
    "binary": "chai",
    "subcommand": "file delete",
    "args": [
      {
        "param": "path",
        "kind": "flag",
        "flag": "path",
        "writePath": true
      }
    ],
    "successExitCodes": [0],
    "hintConditions": [
      {
        "exitCode": 0,
        "hint": "file deleted — verify this was intended"
      }
    ]
  },
  {
    "tool": "files_delete_dir",
    "binary": "chai",
    "subcommand": "file delete-dir",
    "args": [
      {
        "param": "path",
        "kind": "flag",
        "flag": "path",
        "writePath": true
      }
    ],
    "successExitCodes": [0],
    "hintConditions": [
      {
        "exitCode": 0,
        "hint": "directory deleted — verify this was intended"
      }
    ]
  }
]
