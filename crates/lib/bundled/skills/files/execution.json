      { "param": "start_line", "kind": "flag", "flag": "start-line" },
      {
        "param": "end_line",
        "kind": "flag",
        "flag": "end-line",
        "optional": true
      },
      {
        "param": "expected_content",
        "kind": "tempfile",
        "flag": "expected-content-file"
      },
      {
        "param": "content",
        "kind": "stdin"
      }
    ],
    "maxOutputLines": 200
  },
  {
    "tool": "files_replace",
