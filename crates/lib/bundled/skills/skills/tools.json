{
  "tools": [
    {
      "name": "skills_discover",
      "description": "Run a CLI binary's help output to discover its interface. Call without subcommand first to see all subcommands, then with subcommand to get detailed flags and parameters.",
      "parameters": {
        "type": "object",
        "required": ["binary"],
        "properties": {
          "binary": {
            "type": "string",
            "description": "CLI binary name to discover (e.g. 'chai', 'git', 'rg')"
          },
          "subcommand": {
            "type": "string",
            "description": "Specific subcommand to get detailed help for (e.g. 'search', 'create')"
          }
        }
      }
    },
    {
      "name": "skills_list",
      "description": "List all installed skills showing SKILL.md and tools.json population status and tool count.",
      "parameters": {
        "type": "object",
        "required": [],
        "properties": {}
      }
    },
    {
      "name": "skills_read",
      "description": "Read a skill's SKILL.md or tools.json file content.",
      "parameters": {
        "type": "object",
        "required": ["skill_name", "file"],
        "properties": {
          "skill_name": {
            "type": "string",
            "description": "Skill directory name (e.g. 'files', 'git', 'notes')"
          },
          "file": {
            "type": "string",
            "description": "File to read: 'skill_md' for SKILL.md, 'tools_json' for tools.json"
          }
        }
      }
    },
    {
      "name": "skills_validate",
      "description": "Validate a skill's tools.json for schema conformance. Reports errors (must fix) and warnings (should review).",
      "parameters": {
        "type": "object",
        "required": ["skill_name"],
        "properties": {
          "skill_name": {
            "type": "string",
            "description": "Skill directory name to validate"
          }
        }
      }
    },
    {
      "name": "skills_init",
      "description": "Initialize a new skill directory with template SKILL.md and empty tools.json. Fails if the skill already exists.",
      "parameters": {
        "type": "object",
        "required": ["skill_name"],
        "properties": {
          "skill_name": {
            "type": "string",
            "description": "Name for the new skill directory"
          },
          "description": {
            "type": "string",
            "description": "Short description for the skill's SKILL.md frontmatter"
          }
        }
      }
    },
    {
      "name": "skills_write_skill_md",
      "description": "Write or overwrite SKILL.md for a skill. Content must be complete markdown with YAML frontmatter.",
      "parameters": {
        "type": "object",
        "required": ["skill_name", "content"],
        "properties": {
          "skill_name": {
            "type": "string",
            "description": "Skill directory name"
          },
          "content": {
            "type": "string",
            "description": "Complete SKILL.md content including --- frontmatter delimiters"
          }
        }
      }
    },
    {
      "name": "skills_write_tools_json",
      "description": "Write or overwrite tools.json for a skill. Validates JSON syntax before writing. Content must conform to the tools schema.",
      "parameters": {
        "type": "object",
        "required": ["skill_name", "content"],
        "properties": {
          "skill_name": {
            "type": "string",
            "description": "Skill directory name"
          },
          "content": {
            "type": "string",
            "description": "Complete tools.json content as a valid JSON string"
          }
        }
      }
    },
    {
      "name": "skills_write_script",
      "description": "Write a script to a skill's scripts/ directory. Creates the directory if needed. Scripts are referenced by resolveCommand in tools.json.",
      "parameters": {
        "type": "object",
        "required": ["skill_name", "script_name", "content"],
        "properties": {
          "skill_name": {
            "type": "string",
            "description": "Skill directory name"
          },
          "script_name": {
            "type": "string",
            "description": "Script filename without extension (e.g. 'resolve-daily-path'). The .sh extension is added automatically."
          },
          "content": {
            "type": "string",
            "description": "Complete script content including #!/bin/sh shebang line"
          }
        }
      }
    },
    {
      "name": "skills_delete",
      "description": "Delete an initialized skill package. Removes the skill directory and all version snapshots. This action is irreversible.",
      "parameters": {
        "type": "object",
        "required": ["skill_name"],
        "properties": {
          "skill_name": {
            "type": "string",
            "description": "Skill directory name to delete (e.g. 'test-skill', 'myfeed')"
          }
        }
      }
    }
  ],
  "allowlist": {
    "chai": [
      "skill discover",
      "skill list",
      "skill read",
      "skill validate",
      "skill init",
      "skill write-skill-md",
      "skill write-tools-json",
      "skill write-script",
      "skill delete"
    ]
  },
  "execution": [
    {
      "tool": "skills_discover",
      "binary": "chai",
      "subcommand": "skill discover",
      "args": [
        { "param": "binary", "kind": "positional" },
        { "param": "subcommand", "kind": "flag", "flag": "subcommand" }
      ],
      "maxOutputLines": 200
    },
    {
      "tool": "skills_list",
      "binary": "chai",
      "subcommand": "skill list",
      "args": []
    },
    {
      "tool": "skills_read",
      "binary": "chai",
      "subcommand": "skill read",
      "args": [
        { "param": "skill_name", "kind": "positional" },
        { "param": "file", "kind": "flag", "flag": "file" }
      ],
      "maxOutputLines": 500
    },
    {
      "tool": "skills_validate",
      "binary": "chai",
      "subcommand": "skill validate",
      "args": [{ "param": "skill_name", "kind": "positional" }],
      "successExitCodes": [1],
      "postProcess": {
        "script": "hint-validate-errors",
        "args": ["$skill_name"]
      }
    },
    {
      "tool": "skills_init",
      "binary": "chai",
      "subcommand": "skill init",
      "args": [
        { "param": "skill_name", "kind": "positional" },
        { "param": "description", "kind": "flag", "flag": "description" }
      ],
      "postProcess": {
        "script": "hint-init-next-steps"
      }
    },
    {
      "tool": "skills_write_skill_md",
      "binary": "chai",
      "subcommand": "skill write-skill-md",
      "args": [
        { "param": "skill_name", "kind": "positional" },
        { "param": "content", "kind": "stdin" }
      ],
      "postProcess": {
        "script": "hint-skill-md-checks",
        "args": ["$skill_name"]
      }
    },
    {
      "tool": "skills_write_tools_json",
      "binary": "chai",
      "subcommand": "skill write-tools-json",
      "args": [
        { "param": "skill_name", "kind": "positional" },
        { "param": "content", "kind": "stdin" }
      ],
      "postProcess": {
        "script": "hint-validate-on-write"
      }
    },
    {
      "tool": "skills_write_script",
      "binary": "chai",
      "subcommand": "skill write-script",
      "args": [
        { "param": "skill_name", "kind": "positional" },
        { "param": "script_name", "kind": "positional" },
        { "param": "content", "kind": "stdin" }
      ]
    },
    {
      "tool": "skills_delete",
      "binary": "chai",
      "subcommand": "skill delete",
      "args": [
        {
          "param": "skill_name",
          "kind": "positional",
          "denyPattern": "^(files|files-read|git|git-read|git-remote|notes|notes-read|notes-daily|notes-frontmatter|notes-wikilink|logs|rss|skills|skills-design|skills-read)$"
        }
      ]
    }
  ]
}
