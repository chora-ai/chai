[
  {
    "tool": "skills_discover",
    "binary": "chai",
    "subcommand": "skill discover",
    "args": [
      {
        "param": "binary",
        "kind": "positional"
      },
      {
        "param": "subcommand",
        "kind": "flag",
        "flag": "subcommand"
      }
    ],
    "maxOutputLines": 200
  },
  {
    "tool": "skills_list",
    "binary": "chai",
    "subcommand": "skill list",
    "args": []
  },
  {
    "tool": "skills_read",
    "binary": "chai",
    "subcommand": "skill read",
    "args": [
      {
        "param": "skill_name",
        "kind": "positional"
      },
      {
        "param": "file",
        "kind": "flag",
        "flag": "file"
      }
    ],
    "maxOutputLines": 500
  },
  {
    "tool": "skills_validate",
    "binary": "chai",
    "subcommand": "skill validate",
    "args": [
      {
        "param": "skill_name",
        "kind": "positional"
      }
    ],
    "successExitCodes": [1],
    "hintConditions": [
      {
        "match": "ERROR:",
        "hint": "use skills_read with file: 'tools_json', 'allowlist_json', or 'execution_json' to examine the content"
      }
    ]
  },
  {
    "tool": "skills_init",
    "binary": "chai",
    "subcommand": "skill init",
    "args": [
      {
        "param": "skill_name",
        "kind": "positional"
      },
      {
        "param": "description",
        "kind": "flag",
        "flag": "description"
      }
    ],
    "hintConditions": [
      {
        "match": "initialized skill",
        "hint": "skill initialized — next: design tools, write tools.json + allowlist.json + execution.json, then validate"
      }
    ]
  },
  {
    "tool": "skills_write_skill_md",
    "binary": "chai",
    "subcommand": "skill write-skill-md",
    "args": [
      {
        "param": "skill_name",
        "kind": "positional"
      },
      {
        "param": "content",
        "kind": "stdin"
      }
    ],
    "postProcess": {
      "script": "hint-skill-md-checks",
      "args": ["$skill_name"]
    }
  },
  {
    "tool": "skills_write_tools_json",
    "binary": "chai",
    "subcommand": "skill write-tools-json",
    "args": [
      {
        "param": "skill_name",
        "kind": "positional"
      },
      {
        "param": "content",
        "kind": "stdin"
      }
    ],
    "postProcess": {
      "script": "hint-validate-on-write"
    }
  },
  {
    "tool": "skills_write_allowlist_json",
    "binary": "chai",
    "subcommand": "skill write-allowlist-json",
    "args": [
      {
        "param": "skill_name",
        "kind": "positional"
      },
      {
        "param": "content",
        "kind": "stdin"
      }
    ]
  },
  {
    "tool": "skills_write_execution_json",
    "binary": "chai",
    "subcommand": "skill write-execution-json",
    "args": [
      {
        "param": "skill_name",
        "kind": "positional"
      },
      {
        "param": "content",
        "kind": "stdin"
      }
    ]
  },
  {
    "tool": "skills_write_script",
    "binary": "chai",
    "subcommand": "skill write-script",
    "args": [
      {
        "param": "skill_name",
        "kind": "positional"
      },
      {
        "param": "script_name",
        "kind": "positional"
      },
      {
        "param": "content",
        "kind": "stdin"
      }
    ]
  },
  {
    "tool": "skills_delete",
    "binary": "chai",
    "subcommand": "skill delete",
    "args": [
      {
        "param": "skill_name",
        "kind": "positional",
        "denyPattern": "^(files|files-read|git|git-read|git-remote|notes|notes-read|notes-daily|notes-frontmatter|notes-wikilink|logs|rss|skills|skills-design|skills-read)$"
      }
    ]
  },
  {
    "tool": "skills_dry_run",
    "binary": "chai",
    "subcommand": "skill dry-run",
    "args": [
      {
        "param": "tool",
        "kind": "positional"
      },
      {
        "param": "args",
        "kind": "flag",
        "flag": "args"
      },
      {
        "param": "simulated_output",
        "kind": "flag",
        "flag": "simulated-output",
        "optional": true
      }
    ],
    "maxOutputLines": 200
  }
]
