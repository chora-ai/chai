{
  "tools": [
    {
      "name": "kb_wikilink_backlinks",
      "description": "Find all notes that contain a wikilink to a given note name. Returns file paths and matching lines.",
      "parameters": {
        "type": "object",
        "required": ["note_name"],
        "properties": {
          "note_name": {
            "type": "string",
            "description": "Note name to search for backlinks to (e.g. 'Conventions', 'AI Assistant')"
          },
          "path": {
            "type": "string",
            "description": "Directory path relative to the sandbox root to narrow the search (use ./ prefix). Omit to search all notes."
          }
        }
      }
    },
    {
      "name": "kb_wikilink_outlinks",
      "description": "Extract all wikilink targets from a note. Returns one link target per line (note names only, without brackets).",
      "parameters": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Note path relative to the sandbox root (use ./ prefix)"
          }
        }
      }
    },
    {
      "name": "kb_wikilink_by_tag",
      "description": "Find notes that contain a given tag in their content or frontmatter.",
      "parameters": {
        "type": "object",
        "required": ["tag"],
        "properties": {
          "tag": {
            "type": "string",
            "description": "Tag to search for (e.g. 'agentic-systems' or '#agentic-systems')"
          },
          "path": {
            "type": "string",
            "description": "Directory path relative to the sandbox root to narrow the search (use ./ prefix). Omit to search all notes."
          }
        }
      }
    },
    {
      "name": "kb_wikilink_broken",
      "description": "Check a note for broken wikilinks. Returns a list of link targets that do not resolve to existing notes.",
      "parameters": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Note path relative to the sandbox root (use ./ prefix)"
          },
          "kb_root": {
            "type": "string",
            "description": "Path to the knowledge base directory relative to the sandbox root (e.g. 'my-kb'). Omit when the KB is at the sandbox root."
          }
        }
      }
    },
    {
      "name": "kb_wikilink_rename",
      "description": "Rename a knowledge base note and update all wikilinks that reference it. Both plain links ([[Old Name]]) and aliased links ([[Old Name|alias]]) are updated across all notes in the knowledge base.",
      "parameters": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": {
            "type": "string",
            "description": "Current note path relative to the sandbox root (use ./ prefix)"
          },
          "to": {
            "type": "string",
            "description": "New note path relative to the sandbox root (use ./ prefix)"
          },
          "kb_root": {
            "type": "string",
            "description": "Path to the knowledge base directory relative to the sandbox root (e.g. 'my-kb'). Omit when the KB is at the sandbox root."
          }
        }
      }
    }
  ],
  "allowlist": {
    "grep": ["-rn --include=*.md", "-oP (?<=\\[\\[)[^\\]|]+"],
    "chai": ["file rename-note"]
  },
  "execution": [
    {
      "tool": "kb_wikilink_backlinks",
      "binary": "grep",
      "subcommand": "-rn --include=*.md",
      "args": [
        {
          "param": "note_name",
          "kind": "positional",
          "resolveCommand": {
            "script": "build-backlink-pattern",
            "args": ["$param"]
          }
        },
        {
          "param": "path",
          "kind": "positional",
          "readPath": true,
          "optional": true,
          "resolveCommand": {
            "script": "resolve-kb-path",
            "args": ["$param"]
          }
        }
      ],
      "successExitCodes": [0, 1]
    },
    {
      "tool": "kb_wikilink_outlinks",
      "binary": "grep",
      "subcommand": "-oP (?<=\\[\\[)[^\\]|]+",
      "args": [
        {
          "param": "path",
          "kind": "positional",
          "readPath": true,
          "resolveCommand": {
            "script": "resolve-kb-path",
            "args": ["$param"]
          }
        }
      ],
      "postProcess": {
        "script": "sanitize-outlinks"
      },
      "successExitCodes": [0, 1]
    },
    {
      "tool": "kb_wikilink_by_tag",
      "binary": "grep",
      "subcommand": "-rn --include=*.md",
      "args": [
        {
          "param": "tag",
          "kind": "positional",
          "resolveCommand": {
            "script": "normalize-tag",
            "args": ["$param"]
          }
        },
        {
          "param": "path",
          "kind": "positional",
          "readPath": true,
          "optional": true,
          "resolveCommand": {
            "script": "resolve-kb-path",
            "args": ["$param"]
          }
        }
      ],
      "successExitCodes": [0, 1]
    },
    {
      "tool": "kb_wikilink_broken",
      "binary": "grep",
      "subcommand": "-oP (?<=\\[\\[)[^\\]|]+",
      "args": [
        {
          "param": "path",
          "kind": "positional",
          "readPath": true,
          "resolveCommand": {
            "script": "resolve-kb-path",
            "args": ["$param"]
          }
        }
      ],
      "postProcess": {
        "script": "check-broken-links",
        "args": ["$kb_root"],
        "emptyIsResult": true
      },
      "successExitCodes": [0, 1]
    },
    {
      "tool": "kb_wikilink_rename",
      "binary": "chai",
      "subcommand": "file rename-note",
      "args": [
        {
          "param": "from",
          "kind": "flag",
          "flag": "from",
          "writePath": true,
          "resolveCommand": {
            "script": "resolve-kb-path",
            "args": ["$param"]
          }
        },
        {
          "param": "to",
          "kind": "flag",
          "flag": "to",
          "writePath": true,
          "resolveCommand": {
            "script": "resolve-kb-path",
            "args": ["$param"]
          }
        },
        {
          "param": "kb_root",
          "kind": "flag",
          "flag": "root",
          "readPath": true,
          "optional": true,
          "resolveCommand": {
            "script": "resolve-kb-root",
            "args": ["$param"]
          }
        }
      ]
    }
  ]
}
