{
  "tools": [
    {
      "name": "kb_read",
      "description": "Read the contents of a knowledge base note.",
      "parameters": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Note path relative to the sandbox root (use ./ prefix)"
          }
        }
      }
    },
    {
      "name": "kb_read_lines",
      "description": "Read a range of lines from a knowledge base note with line numbers. Returns lines in the format {line_number}|{content}. Use this instead of kb_read when you only need a specific portion of a note to reduce context usage.",
      "parameters": {
        "type": "object",
        "required": ["path", "start_line"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Note path relative to the sandbox root (use ./ prefix)"
          },
          "start_line": {
            "type": "integer",
            "description": "Line number to start reading at (1-indexed, inclusive)"
          },
          "end_line": {
            "type": "integer",
            "description": "Line number to end reading at (1-indexed, inclusive). Defaults to start_line (single line read) if omitted."
          }
        }
      }
    },
    {
      "name": "kb_list",
      "description": "List files and directories at a given path in the knowledge base. When an AGENTS.md file exists in the listed directory, its contents are automatically appended to the listing as a context section — this is not part of the ls output but an automatic context-loading feature.",
      "parameters": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Directory path relative to the sandbox root (use ./ prefix)"
          },
          "long": {
            "type": "boolean",
            "description": "Show detailed format with permissions, size, and dates"
          },
          "all": {
            "type": "boolean",
            "description": "Include hidden files (dotfiles)"
          }
        }
      }
    },
    {
      "name": "kb_search",
      "description": "Search note contents for a pattern using grep. Returns matching lines with context.",
      "parameters": {
        "type": "object",
        "required": ["pattern", "path"],
        "properties": {
          "pattern": {
            "type": "string",
            "description": "Search pattern (extended regex supported)"
          },
          "path": {
            "type": "string",
            "description": "Note or directory path relative to the sandbox root (use ./ prefix)"
          },
          "recursive": {
            "type": "boolean",
            "description": "Search directories recursively. On by default — set to false only when searching a single note path.",
            "default": true
          },
          "line_numbers": {
            "type": "boolean",
            "description": "Show line numbers in output"
          },
          "case_insensitive": {
            "type": "boolean",
            "description": "Ignore case when matching"
          },
          "files_only": {
            "type": "boolean",
            "description": "Show only file names that contain matches, not the matching lines"
          }
        }
      }
    }
  ],
  "allowlist": {
    "cat": [""],
    "ls": [""],
    "grep": ["", "-E"],
    "chai": ["file read-lines"]
  },
  "execution": [
    {
      "tool": "kb_read",
      "binary": "cat",
      "subcommand": "",
      "args": [
        {
          "param": "path",
          "kind": "positional",
          "readPath": true
        }
      ],
      "maxOutputLines": 500
    },
    {
      "tool": "kb_read_lines",
      "binary": "chai",
      "subcommand": "file read-lines",
      "args": [
        {
          "param": "path",
          "kind": "flag",
          "flag": "path",
          "readPath": true
        },
        {
          "param": "start_line",
          "kind": "flag",
          "flag": "start-line"
        },
        {
          "param": "end_line",
          "kind": "flag",
          "flag": "end-line",
          "optional": true
        }
      ]
    },
    {
      "tool": "kb_list",
      "binary": "ls",
      "subcommand": "",
      "args": [
        {
          "param": "long",
          "kind": "flagifboolean",
          "flagIfTrue": "-l"
        },
        {
          "param": "all",
          "kind": "flagifboolean",
          "flagIfTrue": "-a"
        },
        {
          "param": "path",
          "kind": "positional",
          "readPath": true
        }
      ],
      "postProcess": {
        "script": "sanitize-ls"
      },
      "sideRead": {
        "pathParam": "path",
        "filename": "AGENTS.md",
        "oncePerSession": true
      }
    },
    {
      "tool": "kb_search",
      "binary": "grep",
      "subcommand": "-E",
      "args": [
        {
          "param": "recursive",
          "kind": "flagifboolean",
          "flagIfTrue": "--recursive",
          "absentDefault": true
        },
        {
          "param": "line_numbers",
          "kind": "flagifboolean",
          "flagIfTrue": "--line-number"
        },
        {
          "param": "case_insensitive",
          "kind": "flagifboolean",
          "flagIfTrue": "--ignore-case"
        },
        {
          "param": "files_only",
          "kind": "flagifboolean",
          "flagIfTrue": "--files-with-matches"
        },
        {
          "param": "pattern",
          "kind": "positional"
        },
        {
          "param": "path",
          "kind": "positional",
          "readPath": true
        }
      ],
      "successExitCodes": [0, 1],
      "maxOutputLines": 200
    }
  ]
}
