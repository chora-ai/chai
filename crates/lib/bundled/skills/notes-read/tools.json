{
  "tools": [
    {
      "name": "notes_read",
      "description": "Read the contents of a note.",
      "parameters": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Note path relative to the sandbox root (use ./ prefix)"
          }
        }
      }
    },
    {
      "name": "notes_read_lines",
      "description": "Read a range of lines from a note with line numbers. Returns lines in the format {line_number}\\t{content}. Use this instead of notes_read when you only need a specific portion of a note to reduce context usage, or when notes_read output is truncated to read the remaining lines. When end_line is omitted, reads from start_line to the end of the file.",
      "parameters": {
        "type": "object",
        "required": ["path", "start_line"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Note path relative to the sandbox root (use ./ prefix)"
          },
          "start_line": {
            "type": "integer",
            "description": "Line number to start reading at (1-indexed, inclusive)"
          },
          "end_line": {
            "type": "integer",
            "description": "Line number to end reading at (1-indexed, inclusive). When omitted, reads from start_line to the end of the file."
          }
        }
      }
    },
    {
      "name": "notes_list",
      "description": "List files and directories at a given path. When an AGENTS.md file exists in the listed directory, its contents are automatically appended to the listing as a context section — this is not part of the ls output but an automatic context-loading feature.",
      "parameters": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Directory path relative to the sandbox root (use ./ prefix)"
          },
          "long": {
            "type": "boolean",
            "description": "Show detailed format with permissions, size, and dates"
          },
          "all": {
            "type": "boolean",
            "description": "Include hidden files (dotfiles)"
          }
        }
      }
    },
    {
      "name": "notes_search",
      "description": "Search note contents for a pattern using grep. Returns matching lines with context.",
      "parameters": {
        "type": "object",
        "required": ["pattern", "path"],
        "properties": {
          "pattern": {
            "type": "string",
            "description": "Search pattern (extended regex supported)"
          },
          "path": {
            "type": "string",
            "description": "Note or directory path relative to the sandbox root (use ./ prefix)"
          },
          "recursive": {
            "type": "boolean",
            "description": "Search directories recursively. On by default — set to false only when searching a single note path.",
            "default": true
          },
          "line_number": {
            "type": "boolean",
            "description": "Show line numbers in output",
            "default": true
          },
          "ignore_case": {
            "type": "boolean",
            "description": "Ignore case when matching"
          },
          "files_with_matches": {
            "type": "boolean",
            "description": "Show only file names that contain matches, not the matching lines"
          }
        }
      }
    }
  ],
  "allowlist": {
    "cat": [""],
    "ls": [""],
    "grep": ["", "-E"],
    "chai": ["file read-lines"]
  },
  "execution": [
    {
      "tool": "notes_read",
      "binary": "cat",
      "subcommand": "",
      "args": [
        {
          "param": "path",
          "kind": "positional",
          "readPath": true
        }
      ],
      "successExitCodes": [1],
      "postProcess": {
        "script": "hint-not-found"
      },
      "maxOutputLines": 500,
      "truncationHint": "output truncated: {kept} of {total} lines shown; {omitted} lines omitted. Use notes_read_lines with start_line: {next_start} to read the remaining lines."
    },
    {
      "tool": "notes_read_lines",
      "binary": "chai",
      "subcommand": "file read-lines",
      "args": [
        {
          "param": "path",
          "kind": "flag",
          "flag": "path",
          "readPath": true
        },
        {
          "param": "start_line",
          "kind": "flag",
          "flag": "start-line"
        },
        {
          "param": "end_line",
          "kind": "flag",
          "flag": "end-line",
          "optional": true
        }
      ],
      "successExitCodes": [1],
      "postProcess": {
        "script": "hint-not-found"
      }
    },
    {
      "tool": "notes_list",
      "binary": "ls",
      "subcommand": "",
      "args": [
        {
          "param": "long",
          "kind": "flagifboolean",
          "flagIfTrue": "-l"
        },
        {
          "param": "all",
          "kind": "flagifboolean",
          "flagIfTrue": "-a"
        },
        {
          "param": "path",
          "kind": "positional",
          "readPath": true
        }
      ],
      "maxOutputLines": 200,
      "postProcess": {
        "script": "sanitize-ls"
      },
      "sideRead": {
        "pathParam": "path",
        "filename": "AGENTS.md",
        "oncePerSession": true
      }
    },
    {
      "tool": "notes_search",
      "binary": "grep",
      "subcommand": "-E",
      "args": [
        {
          "param": "recursive",
          "kind": "flagifboolean",
          "flagIfTrue": "--recursive",
          "absentDefault": true
        },
        {
          "param": "line_number",
          "kind": "flagifboolean",
          "flagIfTrue": "--line-number",
          "absentDefault": true
        },
        {
          "param": "ignore_case",
          "kind": "flagifboolean",
          "flagIfTrue": "--ignore-case"
        },
        {
          "param": "files_with_matches",
          "kind": "flagifboolean",
          "flagIfTrue": "--files-with-matches"
        },
        {
          "param": "pattern",
          "kind": "positional"
        },
        {
          "param": "path",
          "kind": "positional",
          "readPath": true
        }
      ],
      "successExitCodes": [0, 1],
      "postProcess": {
        "script": "hint-search-results"
      },
      "maxOutputLines": 200
    }
  ]
}