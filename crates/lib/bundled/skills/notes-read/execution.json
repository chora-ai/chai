  {
    "tool": "notes_read_lines",
    "binary": "chai",
    "subcommand": "file read-lines",
    "args": [
      {
        "param": "path",
        "kind": "flag",
        "flag": "path",
        "readPath": true
      },
      {
        "param": "start_line",
        "kind": "flag",
        "flag": "start-line"
      },
      {
        "param": "end_line",
        "kind": "flag",
        "flag": "end-line",
        "optional": true
      }
    ],
    "successExitCodes": [1],
    "hintConditions": [
      {
        "exitCode": "nonzero",
        "hint": "note not found — use notes_list to list available notes"
      }
    ]
  },
  {
    "tool": "notes_list",
    "binary": "ls",
    "subcommand": "",
    "args": [
      {
        "param": "long",
        "kind": "flagifboolean",
        "flagIfTrue": "-l"
      },
      {
        "param": "all",
        "kind": "flagifboolean",
        "flagIfTrue": "-a"
